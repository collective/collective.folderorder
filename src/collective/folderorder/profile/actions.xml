<?xml version="1.0"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Plone Actions Tool"
        name="portal_actions"
>
  <object meta_type="CMF Action Category"
          name="object_buttons"
  >
    <property name="title" />
    <object meta_type="CMF Action"
            name="order"
            i18n:domain="plone"
    >
      <property name="title"
                i18n:translate=""
      >Order</property>
      <property name="description"
                i18n:translate=""
      />
      <property name="url_expr">string:$object_url/select_folder_order</property>
      <property name="available_expr">python:object.restrictedTraverse('@@is_orderable_folder')()</property>
      <property name="permissions">
        <element value="Manage properties" />
      </property>
      <property name="visible">True</property>
    </object>
  </object>
</object>
